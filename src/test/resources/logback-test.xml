<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Quieter logging for tests: WARN by default to reduce noise -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %C{5} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Application logs: WARN in tests (set to INFO temporarily when debugging) -->
    <logger name="uk.gov.hmcts" level="INFO"/>
</configuration>
