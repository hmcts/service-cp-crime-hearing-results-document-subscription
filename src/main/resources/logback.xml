<configuration>
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <mdc/>
                <timestamp>
                    <fieldName>timestamp</fieldName>
                    <pattern>yyyy-MM-dd' 'HH:mm:ss.SSS</pattern>
                </timestamp>
                <message/>
                <loggerName/>
                <threadName/>
                <logLevel/>
                <pattern>
                    <pattern>{"exception": "%xException{full}"}</pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!-- Reduce the huge noise coming from Azure SDK -->
    <logger name="com.azure.core" level="WARN"/>
    <logger name="com.azure.messaging" level="WARN"/>
    <logger name="com.azure.core.amqp.implementation" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>
</configuration>