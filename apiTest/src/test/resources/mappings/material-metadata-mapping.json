{
  "request": {
    "method": "GET",
    "urlPattern": "/material-query-api/query/api/rest/material/material/([a-zA-Z0-8-]*)/metadata",
    "headers": {
      "X-Correlation-Id": {
        "matches": "^([a-zA-Z0-9-]*)$"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "material-response.json",
    "transformers": ["response-template"]
  }
}
